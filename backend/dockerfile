# Stage 1
FROM maven:3.9.6-eclipse-temurin-17 AS build
WORKDIR /app
COPY backend/ .
RUN mvn clean package -DskipTests

# Stage 2
FROM eclipse-temurin:17-jdk
WORKDIR /app

# 👇 IMPORTANT: use shaded jar explicitly
COPY --from=build /app/target/backend-1.0-SNAPSHOT-shaded.jar app.jar

EXPOSE 8080
CMD ["java", "-jar", "app.jar"]